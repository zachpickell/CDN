# Copy this file to .env.local and fill in real values.

# The single password used to log in to the dashboard.
APP_PASSWORD=change-me-to-a-strong-password

# Secret used to sign session cookies. Use a long random string.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# (Optional) where uploaded files + metadata are stored.
# Defaults to ./storage in the project root.
# DATA_DIR=/absolute/path/to/storage
